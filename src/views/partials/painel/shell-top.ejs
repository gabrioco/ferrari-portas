<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — Painel' : 'Painel Ferrari Portas' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400&display=swap" />
  <style>
    :root { --sidebar-w: 240px; }
    body { font-family: 'Space Grotesk', sans-serif; }
    .mono { font-family: 'Space Mono', monospace; }
  </style>
</head>
<body class="bg-neutral-100 text-neutral-900 antialiased min-h-screen flex">

  <!-- SIDEBAR -->
  <aside style="width: var(--sidebar-w)" class="fixed top-0 left-0 h-full bg-neutral-950 flex flex-col z-20">

    <div class="px-6 pt-8 pb-6 border-b border-neutral-800">
      <span class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-500 block mb-1">painel</span>
      <span class="text-white font-bold text-base leading-tight">Ferrari Portas</span>
    </div>

    <nav class="flex-1 px-3 py-6 space-y-1">
      <a href="/painel"
         class="flex items-center gap-3 px-3 py-2.5 rounded-sm text-sm font-medium transition-colors
                <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'bg-white/10 text-white' : 'text-neutral-400 hover:text-white hover:bg-white/5' %>">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
        </svg>
        Dashboard
      </a>

      <a href="/painel/produtos"
         class="flex items-center gap-3 px-3 py-2.5 rounded-sm text-sm font-medium transition-colors
                <%= typeof activePage !== 'undefined' && activePage === 'produtos' ? 'bg-white/10 text-white' : 'text-neutral-400 hover:text-white hover:bg-white/5' %>">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
        </svg>
        Produtos
      </a>

      <a href="/painel/categorias"
         class="flex items-center gap-3 px-3 py-2.5 rounded-sm text-sm font-medium transition-colors
                <%= typeof activePage !== 'undefined' && activePage === 'categorias' ? 'bg-white/10 text-white' : 'text-neutral-400 hover:text-white hover:bg-white/5' %>">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
        </svg>
        Categorias
      </a>
    </nav>

    <div class="px-4 py-5 border-t border-neutral-800">
      <div class="flex items-center justify-between gap-2">
        <div class="min-w-0">
          <p class="text-white text-sm font-medium truncate"><%= typeof user !== 'undefined' ? user.email : '' %></p>
          <p class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-500 mt-0.5">admin</p>
        </div>
        <form method="POST" action="/painel/logout">
          <button type="submit" title="Sair"
                  class="p-1.5 rounded-sm text-neutral-500 hover:text-white hover:bg-white/10 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
            </svg>
          </button>
        </form>
      </div>
    </div>

  </aside>

  <!-- MAIN WRAPPER -->
  <div class="flex-1 flex flex-col" style="margin-left: var(--sidebar-w)">

    <!-- Topbar -->
    <header class="h-14 bg-white border-b border-neutral-200 flex items-center px-8 sticky top-0 z-10">
      <h1 class="text-sm font-semibold text-neutral-800"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
    </header>

    <!-- Page content starts here -->
    <main class="flex-1 px-8 py-8">
