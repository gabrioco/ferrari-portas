<%- include('../../partials/painel/shell-top', { title: 'Dashboard', activePage: 'dashboard', user }) %>

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">

    <div class="bg-white border border-neutral-200 rounded-sm p-6">
      <span class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-400 block mb-3">Total de produtos</span>
      <p class="text-3xl font-bold text-neutral-900"><%= typeof stats !== 'undefined' ? stats.totalProdutos : '—' %></p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-sm p-6">
      <span class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-400 block mb-3">Produtos ativos</span>
      <p class="text-3xl font-bold text-neutral-900"><%= typeof stats !== 'undefined' ? stats.produtosAtivos : '—' %></p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-sm p-6">
      <span class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-400 block mb-3">Produtos inativos</span>
      <p class="text-3xl font-bold text-neutral-900"><%= typeof stats !== 'undefined' ? stats.produtosInativos : '—' %></p>
    </div>

  </div>

  <!-- Quick actions -->
  <div class="bg-white border border-neutral-200 rounded-sm p-6">
    <span class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-400 block mb-4">Ações rápidas</span>
    <div class="flex flex-wrap gap-3">
      <a href="/painel/produtos/novo"
         class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-950 text-white text-sm font-medium rounded-sm hover:bg-neutral-800 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Novo produto
      </a>
      <a href="/painel/produtos"
         class="inline-flex items-center gap-2 px-4 py-2 border border-neutral-200 text-neutral-700 text-sm font-medium rounded-sm hover:bg-neutral-50 transition-colors">
        Ver todos os produtos
      </a>
    </div>
  </div>

<%- include('../../partials/painel/shell-bottom') %>
