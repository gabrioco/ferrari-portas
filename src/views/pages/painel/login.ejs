<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Entrar — Ferrari Portas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400&display=swap" />
  <style>
    body { font-family: 'Space Grotesk', sans-serif; }
    .mono { font-family: 'Space Mono', monospace; }
  </style>
</head>
<body class="bg-neutral-950 text-white antialiased min-h-screen flex items-center justify-center px-4">

  <div class="w-full max-w-sm">

    <!-- Logo / brand -->
    <div class="mb-10 text-center">
      <span class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-500 block mb-3">área restrita</span>
      <h1 class="text-2xl font-bold tracking-tight">Ferrari Portas</h1>
    </div>

    <!-- Card -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-sm p-8">

      <h2 class="text-base font-semibold mb-6">Entrar no painel</h2>

      <% if (error) { %>
        <div class="mb-5 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-sm">
          <p class="text-sm text-red-400"><%= error %></p>
        </div>
      <% } %>

      <form method="POST" action="/painel/login" class="space-y-5">

        <div>
          <label class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-400 block mb-2">Email</label>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full bg-neutral-800 border border-neutral-700 rounded-sm px-4 py-2.5 text-sm text-white placeholder-neutral-600
                   focus:outline-none focus:border-neutral-500 transition-colors"
            placeholder="seu@email.com"
          />
        </div>

        <div>
          <label class="mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-400 block mb-2">Senha</label>
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="w-full bg-neutral-800 border border-neutral-700 rounded-sm px-4 py-2.5 text-sm text-white placeholder-neutral-600
                   focus:outline-none focus:border-neutral-500 transition-colors"
            placeholder="••••••••"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-white text-neutral-950 font-semibold text-sm py-2.5 rounded-sm
                 hover:bg-neutral-100 active:bg-neutral-200 transition-colors mt-2">
          Entrar
        </button>

      </form>
    </div>

    <p class="text-center mono text-[0.6rem] uppercase tracking-[0.2em] text-neutral-700 mt-8">
      Ferrari Portas &copy; <%= new Date().getFullYear() %>
    </p>

  </div>

</body>
</html>
